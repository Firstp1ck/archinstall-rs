/target
# archinstall-rs.config.toml
# *.log
# Root-only: do not ignore Documents/RELEASE_v*.md (release.sh + CI)
/RELEASE*.md
possible_debug.md
limine_implementation_plan.md
# Ignore everything in target
/target/*

# Allow the release dir
!/target/release/

# Ignore everything inside release by default
/target/release/*

# Keep only the binary
!/target/release/archinstall-rs

dev/COMMIT/*
dev/PR/*
